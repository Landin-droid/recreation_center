generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  staff
  user
}

model User {
  userId               Int            @id @default(autoincrement()) @map("user_id")
  fullName             String         @map("full_name")
  email                String         @unique
  phoneNumber          String?        @map("phone_number")
  registrationDate     DateTime       @default(now()) @map("registration_date")
  passwordHash         String         @map("password_hash")
  role                 UserRole       @default(user)
  resetPasswordToken   String?        @map("reset_password_token")
  resetPasswordExpires DateTime?      @map("reset_password_expires")
  refreshTokens        RefreshToken[]
  reservations         Reservation[]

  @@map("user")
}

model RefreshToken {
  refreshTokenId Int       @id @default(autoincrement()) @map("refresh_token_id")
  userId         Int       @map("user_id")
  tokenHash      String    @unique @map("token_hash")
  expiresAt      DateTime  @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  revokedAt      DateTime? @map("revoked_at")
  user           User      @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_token")
}

model BookableObject {
  bookableObjectId Int                @id @default(autoincrement()) @map("bookable_object_id")
  name             String
  capacity         Int
  basePrice        Decimal            @map("base_price")
  isSeasonal       Boolean            @default(false) @map("is_seasonal")
  seasonStart      DateTime?          @map("season_start") @db.Date
  seasonEnd        DateTime?          @map("season_end") @db.Date
  description      String?
  isActive         Boolean            @default(true) @map("is_active")
  imageUrls        String[]           @default([]) @map("image_urls")
  type             BookableObjectType
  banquetHall      BanquetHall?
  cottage          Cottage?
  gazebo           Gazebo?
  karaokeBar       KaraokeBar?
  outdoorVenue     OutdoorVenue?
  objectMenuItems  ObjectMenuItem[]
  reservations     Reservation[]

  @@map("bookable_object")
}

model Cottage {
  bookableObjectId Int            @id @map("bookable_object_id")
  amenities        String?
  squareMeters     Int?           @map("square_meters")
  bookableObject   BookableObject @relation(fields: [bookableObjectId], references: [bookableObjectId], onDelete: Cascade)

  @@map("cottage")
}

model Gazebo {
  bookableObjectId Int            @id @map("bookable_object_id")
  amenities        String?
  bookableObject   BookableObject @relation(fields: [bookableObjectId], references: [bookableObjectId], onDelete: Cascade)

  @@map("gazebo")
}

model BanquetHall {
  bookableObjectId Int            @id @map("bookable_object_id")
  maxTables        Int?           @map("max_tables")
  bookableObject   BookableObject @relation(fields: [bookableObjectId], references: [bookableObjectId], onDelete: Cascade)

  @@map("banquet_hall")
}

model OutdoorVenue {
  bookableObjectId Int            @id @map("bookable_object_id")
  bookableObject   BookableObject @relation(fields: [bookableObjectId], references: [bookableObjectId], onDelete: Cascade)

  @@map("outdoor_venue")
}

model KaraokeBar {
  bookableObjectId Int            @id @map("bookable_object_id")
  tablesAmount     Int?           @map("tables_amount")
  bookableObject   BookableObject @relation(fields: [bookableObjectId], references: [bookableObjectId], onDelete: Cascade)

  @@map("karaoke_bar")
}

model Reservation {
  reservationId        Int                    @id @default(autoincrement()) @map("reservation_id")
  userId               Int                    @map("user_id")
  bookableObjectId     Int                    @map("bookable_object_id")
  reservationDate      DateTime               @map("reservation_date") @db.Date
  creationDate         DateTime               @default(now()) @map("creation_date")
  guestsCount          Int                    @map("guests_count")
  totalSum             Decimal                @map("total_sum")
  notes                String?
  status               ReservationStatus      @default(pending)
  paymentDeadline      DateTime?              @map("payment_deadline")
  payment              Payment?
  bookableObject       BookableObject         @relation(fields: [bookableObjectId], references: [bookableObjectId])
  user                 User                   @relation(fields: [userId], references: [userId])
  reservationMenuItems ReservationMenuItem[]

  @@index([bookableObjectId, reservationDate])
  @@index([paymentDeadline])
  @@map("reservation")
}

model Payment {
  paymentId         Int              @id @default(autoincrement()) @map("payment_id")
  reservationId     Int              @unique @map("reservation_id")
  paymentDate       DateTime         @default(now()) @map("payment_date")
  amount            Decimal
  kassaPaymentId    String?          @unique @map("kassa_payment_id")
  idempotencyKey    String           @unique @map("idempotency_key")
  status            PaymentStatus    @default(pending)
  method            PaymentMethod?
  reservation       Reservation      @relation(fields: [reservationId], references: [reservationId], onDelete: Cascade)
  refund            Refund?
  receipt           Receipt? 

  @@index([status])
  @@map("payment")
}

model Refund {
  refundId           Int                @id @default(autoincrement()) @map("refund_id")
  paymentId          Int                @unique @map("payment_id")
  originalAmount     Decimal            @map("original_amount")
  refundAmount       Decimal            @map("refund_amount")
  reason             String?
  cancellationParty  String?            @map("cancellation_party")
  cancellationReason String?            @map("cancellation_reason")
  kassaRefundId      String?            @unique @map("kassa_refund_id")
  status             RefundStatus       @default(pending) @map("status")
  createdAt          DateTime           @default(now()) @map("created_at")
  completedAt        DateTime?          @map("completed_at")
  payment            Payment            @relation(fields: [paymentId], references: [paymentId], onDelete: Cascade)
  receipt            Receipt?

  @@index([status, createdAt])
  @@index([paymentId])
  @@map("refund")
}

model Receipt {
  receiptId       Int          @id @default(autoincrement()) @map("receipt_id")
  kassaReceiptId  String       @unique @map("kassa_receipt_id")
  type            ReceiptType
  status          String?
  paymentId       Int?         @unique @map("payment_id")
  refundId        Int?         @unique @map("refund_id")
  rawPayload      Json?        @map("raw_payload")
  createdAt       DateTime     @default(now()) @map("created_at")

  payment         Payment?     @relation(fields: [paymentId], references: [paymentId])
  refund          Refund?      @relation(fields: [refundId], references: [refundId])

  @@map("receipt")
}

model MenuItem {
  menuItemId           Int                   @id @default(autoincrement()) @map("menu_item_id")
  name                 String
  price                Decimal
  description          String?
  isAvailable          Boolean               @default(true) @map("is_available")
  category             MenuCategory?
  objectMenuItems      ObjectMenuItem[]
  reservationMenuItems ReservationMenuItem[]

  @@map("menu_item")
}

model ReservationMenuItem {
  quantity      Int
  itemCost      Decimal     @map("item_cost")
  menuItemId    Int
  reservationId Int
  menuItem      MenuItem    @relation(fields: [menuItemId], references: [menuItemId])
  reservation   Reservation @relation(fields: [reservationId], references: [reservationId], onDelete: Cascade)

  @@id([reservationId, menuItemId])
  @@map("reservation_menu_item")
}

model ObjectMenuItem {
  isAvailable      Boolean        @default(true) @map("is_available")
  bookableObjectId Int
  menuItemId       Int
  bookableObject   BookableObject @relation(fields: [bookableObjectId], references: [bookableObjectId], onDelete: Cascade)
  menuItem         MenuItem       @relation(fields: [menuItemId], references: [menuItemId], onDelete: Cascade)

  @@id([menuItemId, bookableObjectId])
  @@index([bookableObjectId, isAvailable])
  @@map("object_menu_item")
}

model RentalItem {
  rentalItemId Int               @id @default(autoincrement()) @map("rental_item_id")
  name         String
  description  String?
  pricePerHour Decimal?          @map("price_per_hour")
  isSeasonal   Boolean           @default(false) @map("is_seasonal")
  maxCapacity  Int?              @map("max_capacity")
  imageUrl     String?           @map("image_url")
  isActive     Boolean           @default(true) @map("is_active")
  category     RentalCategory
  seasonType   RentalSeasonType? @map("season_type")
  priceRules   RentalPriceRule[]

  @@index([category, isActive])
  @@index([isSeasonal, seasonType])
  @@map("rental_item")
}

model RentalPriceRule {
  ruleId        Int           @id @default(autoincrement()) @map("rule_id")
  rentalItemId  Int           @map("rental_item_id")
  pricePerKm    Decimal       @map("price_per_km")
  minKm         Int           @default(1) @map("min_km")
  maxKm         Decimal?      @map("max_km")
  passengerType PassengerType @map("passenger_type")
  rentalItem    RentalItem    @relation(fields: [rentalItemId], references: [rentalItemId], onDelete: Cascade)

  @@unique([rentalItemId, passengerType])
  @@map("rental_price_rule")
}

model WebhookLog {
  webhookLogId  Int              @id @default(autoincrement()) @map("webhook_log_id")
  source        String           @map("source")
  eventType     WebhookEventType @map("event_type")
  payload       String           @map("payload") @db.Text
  processed     Boolean          @default(false)
  error         String?          @map("error")
  createdAt     DateTime         @default(now()) @map("created_at")

  @@index([source, createdAt])
  @@index([createdAt])
  @@map("webhook_log")
}

enum ReservationStatus {
  pending
  paid
  canceled
  expired
  refunded
}

enum BookableObjectType {
  cottage
  gazebo
  banquet_hall
  outdoor_venue
  karaoke_bar
}

enum PaymentStatus {
  pending
  succeeded
  canceled
}

enum PaymentMethod {
  bank_card
  yoo_money
  sberbank
  alfa_pay
  tinkoff_bank
  sbp
  cash
}

enum MenuCategory {
  food
  drink
  snack
  dessert
}

enum RentalCategory {
  ski
  tube
  snowmobile
  skates
}

enum RentalSeasonType {
  winter
  summer
  year
}

enum PassengerType {
  adult
  child
}

enum RefundStatus {
  pending
  succeeded
  canceled
}

enum WebhookEventType {
  payment_waiting_for_capture
  payment_succeeded
  payment_canceled
  refund_succeeded
}

enum ReceiptType {
  payment
  refund
}
