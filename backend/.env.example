NODE_ENV=development
PORT=5000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=db

DATABASE_URL=postgresql://postgres:password@localhost:5432/db
JWT_SECRET=secret_key_must_be_at_least_32_characters_long_for_production
REFRESH_TOKEN_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ЮKassa Payment Gateway
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_API_KEY=your_api_key
YOOKASSA_WEBHOOK_SECRET=your_webhook_secret

# Payment Configuration
PAYMENT_SUCCESS_REDIRECT=http://localhost:3000/payment/success
PAYMENT_FAILURE_REDIRECT=http://localhost:3000/payment/failure
PAYMENT_TIMEOUT_MINUTES=15

# EmailJS configuration
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_TEMPLATE_RECEIPT_ID=template_payment_receipt_id
EMAILJS_TEMPLATE_RESET_PASSWORD_ID=template_reset_password_id

# App Configuration
FRONTEND_URL=http://localhost:3000